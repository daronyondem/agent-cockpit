{
  "name": "agent-cockpit",
  "version": "0.2.107",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "tsx server.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "web:build": "vite build --config web/AgentCockpitWeb/vite.config.ts",
    "web:budget": "node scripts/check-web-bundle-size.js",
    "web:typecheck": "tsc -p web/AgentCockpitWeb/tsconfig.json --noEmit",
    "auth:reset": "tsx scripts/auth-reset.ts",
    "context-map:report": "tsx scripts/context-map-report.ts",
    "mobile:dev": "npm --prefix mobile/AgentCockpitPWA run dev",
    "mobile:build": "npm --prefix mobile/AgentCockpitPWA run build",
    "mobile:typecheck": "npm --prefix mobile/AgentCockpitPWA run typecheck",
    "adr:new": "node scripts/adr-new.js",
    "adr:index": "node scripts/adr-index.js",
    "adr:lint": "node scripts/adr-lint.js"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@napi-rs/canvas": "^0.1.97",
    "@simplewebauthn/server": "^13.3.0",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.8.0",
    "dompurify": "^3.4.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.18.1",
    "fast-xml-parser": "^5.7.3",
    "helmet": "^8.0.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.3",
    "multer": "^2.1.1",
    "on-headers": "^1.0.2",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pm2": "^7.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "session-file-store": "^1.5.0",
    "unpdf": "^1.4.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie": "^0.6.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.12"
  }
}
