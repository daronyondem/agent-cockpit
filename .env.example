PORT=3334
SESSION_SECRET=replace-with-a-long-random-string
AUTH_DATA_DIR=
AUTH_SETUP_TOKEN=
AUTH_ENABLE_LEGACY_OAUTH=false
# Legacy OAuth only; not required for the default first-party owner login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=
ALLOWED_EMAIL=
DEFAULT_WORKSPACE=~/.openclaw/workspace
BASE_PATH=
CODEX_APPROVAL_POLICY=on-request
CODEX_SANDBOX_MODE=workspace-write
# auto builds stale/missing /v2 and /mobile assets at startup; skip is for tests/special deployments.
WEB_BUILD_MODE=auto
